# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=http://127.0.0.1:54421

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session
SESSION_COOKIE_SECRET=

# Blob storage (S3 protocol). Dev = local Supabase Storage; prod = Cloudflare R2.
STORAGE_ENDPOINT=http://127.0.0.1:54421/storage/v1/s3
STORAGE_REGION=local
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=cvs
STORAGE_FORCE_PATH_STYLE=true

# Third-party ingestion (server-only; absent in local dev — admin trigger errors clearly if needed)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
# Stripe billing (server-only except the publishable key; absent in local dev —
# billing endpoints return CONFLICT until configured)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_SEEKER_MONTHLY=
STRIPE_PRICE_COMPANY_MONTHLY=

# AI-CV providers (server-only; absent in local dev — generate endpoint CONFLICTs
# until configured). AI_PROVIDER_MODE=claude_only forces Claude (Groq DPA gate).
GROQ_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_MODE=
# Ops (server-only; absent in local dev). Cron endpoint 503s without CRON_SECRET;
# email is a logged no-op without RESEND_API_KEY (jobs still succeed).
CRON_SECRET=
RESEND_API_KEY=
RATE_LIMIT_TRUST_FORWARDED=
RATE_LIMIT_IP_ENABLED=
